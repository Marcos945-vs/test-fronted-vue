{
  "extends": "@vue/tsconfig/tsconfig.web.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "compilerOptions": {
  "noEmit": true,
  "verbatimModuleSyntax": false,
  "preserveValueImports": false,
  "importsNotUsedAsValues": "remove",
  "baseUrl": ".",
  "paths": {
    "@/*": ["./src/*"]
  },
    "allowJs": true
  },
  "references": [
    {
      "path": "./tsconfig.vite-config.json"
    }
  ]
}
